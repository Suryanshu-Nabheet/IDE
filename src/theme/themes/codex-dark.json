	"tokenColors": [
		{
			"scope": ["comment", "comment.block", "comment.line", "comment.doc"],
			"settings": { "foreground": "#474747", "fontStyle": "italic" }
		},
		{
			"scope": ["constant", "constant.language", "constant.other", "constant.character.escape", "string.interpolated.special", "string.special", "string.special.symbol"],
			"settings": { "foreground": "#83d6c5" }
		},
		{
			"scope": ["constant.numeric"],
			"settings": { "foreground": "#d6d6dd" }
		},
		{
			"scope": ["constant.language.boolean", "entity.name.tag", "text"],
			"settings": { "foreground": "#fad075" }
		},
		{
			"scope": ["entity.name.function", "support.function"],
			"settings": { "foreground": "#ebc88d" }
		},
		{
			"scope": ["entity.name.function.constructor", "variable.member"],
			"settings": { "foreground": "#FF0000" }
		},
		{
			"scope": ["keyword", "storage", "storage.type", "storage.modifier"],
			"settings": { "foreground": "#83d6c5" }
		},
		{
			"scope": ["variable.language.this"],
			"settings": { "foreground": "#83d6c5" }
		},
		{
			"scope": ["variable", "variable.parameter", "variable.other"],
			"settings": { "foreground": "#aa9bf5" }
		},
		{
			"scope": ["variable.language", "variable.other.special", "variable.special"],
			"settings": { "foreground": "#E1DAE8" }
		},
		{
			"scope": ["variable.other.property", "support.type.property-name", "meta.object-literal.key", "variable.object.property", "punctuation", "punctuation.bracket", "punctuation.delimiter", "punctuation.list_marker", "punctuation.special", "operator", "number"],
			"settings": { "foreground": "#d6d6dd" }
		},
		{
			"scope": ["entity.name.type", "support.type", "support.class", "entity.name.class", "type"],
			"settings": { "foreground": "#87c3ff" }
		},
		{
			"scope": ["entity.other.attribute-name", "attribute"],
			"settings": { "foreground": "#aaa0fa", "fontStyle": "italic" }
		},
		{
			"scope": ["string"],
			"settings": { "foreground": "#e394dc" }
		},
		{
			"scope": ["string.escape", "string.special"],
			"settings": { "foreground": "#CC7832" }
		},
		{
			"scope": ["string.regexp", "string.regex"],
			"settings": { "foreground": "#DA2877" }
		},
		{
			"scope": ["markup.heading", "heading"],
			"settings": { "foreground": "#87c3ff", "fontStyle": "bold" }
		},
		{
			"scope": ["markup.literal", "text.literal"],
			"settings": { "foreground": "#B5BD68" }
		}
	],
	"semanticHighlighting": true
}