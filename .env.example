# CodeX IDE - Environment Configuration
# CodeX works completely offline by default. All settings are optional.

# ============================================
# Development Settings (Optional)
# ============================================
# Enable debug logging
# DEBUG=true

# Log level: ERROR, WARN, INFO, DEBUG
# LOG_LEVEL=INFO

# ============================================
# Language Server Protocol (Optional)
# ============================================
# Override default language server paths if needed

# TypeScript Language Server
# TYPESCRIPT_LSP_PATH=/custom/path/to/typescript-language-server

# Python Language Server
# PYTHON_LSP_PATH=/custom/path/to/pylsp

# ============================================
# Notes
# ============================================
# - CodeX works completely offline without any configuration
# - All features are available locally
# - No authentication or external APIs required
# - Restart CodeX after changing environment variables
