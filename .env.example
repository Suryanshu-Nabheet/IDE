# CodeX Environment Variables

# This is an example file. Copy this to .env and fill in your values.
# The .env file is gitignored and should never be committed.

# ============================================
# Optional: GitHub Copilot Configuration
# ============================================
# Set to false to disable Copilot and suppress related errors
COPILOT_ENABLED=false

# Custom Copilot path (if different from default)
# COPILOT_PATH=/path/to/copilot/dist/agent.js

# ============================================
# Optional: Analytics
# ============================================
# PostHog API key for usage analytics
# POSTHOG_API_KEY=your_posthog_api_key_here

# Disable analytics entirely
# ANALYTICS_ENABLED=false

# ============================================
# Optional: Custom LSP Paths
# ============================================
# Override default language server paths if needed

# TypeScript Language Server
# TYPESCRIPT_LSP_PATH=/custom/path/to/typescript-language-server

# Python Language Server
# PYTHON_LSP_PATH=/custom/path/to/pylsp

# ============================================
# Optional: Development Settings
# ============================================
# Enable debug logging
# DEBUG=true

# Log level: ERROR, WARN, INFO, DEBUG
# LOG_LEVEL=INFO

# ============================================
# Optional: API Configuration
# ============================================
# Custom API endpoints (if self-hosting)
# API_ROOT=https://your-api.example.com
# HOMEPAGE_ROOT=https://your-homepage.example.com

# ============================================
# Optional: Feature Flags
# ============================================
# Enable experimental features
# EXPERIMENTAL_FEATURES=false

# Enable telemetry
# TELEMETRY_ENABLED=false
